# Budget Expense Tracker — environment variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.

# Path to the SQLite database file.
# Local dev: defaults to ./budget.db (persistent, relative to project root).
# Vercel: set to /tmp/budget.db (writable, but EPHEMERAL — data resets on cold starts).
# See docs/adr/ADR-0003-sqlite-vercel.md.
DATABASE_PATH=./budget.db

# Exchange rate API base URL (frankfurter.app — free, keyless).
# Override only in tests or if you want to point at a local mock.
# NOTE: rates are fetched via a server-side Route Handler, never from the client bundle (TC-FX-01).
FX_API_BASE_URL=https://api.frankfurter.app

# Node environment (set automatically by Next.js / Vercel; listed here for clarity).
# NODE_ENV=development
